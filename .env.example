# =============================================================================
# EbookDrive — variáveis de ambiente (template)
# Copie para .env.local e preencha. NUNCA commite valores reais (ver .gitignore).
# Variáveis com prefixo NEXT_PUBLIC_ vão para o navegador — use SÓ para dados públicos.
# =============================================================================

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Checkout dos CTAs da landing ---
# Se preenchido (link de pagamento pronto: Hotmart/Kiwify/Mercado Pago/Stripe Payment Link),
# TODOS os botões de compra levam direto para essa URL. Se vazio, os CTAs chamam
# POST /api/checkout (fluxo Stripe do projeto). Ver components/LandingClient.tsx.
NEXT_PUBLIC_CHECKOUT_URL=

# --- Stripe (skills: stripe-drive-checkout, fraud-prevention) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx
# Publishable key só é necessária se usar Stripe.js no client (opcional neste fluxo por redirect):
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Google Drive (entrega Opção B — permissão individual por e-mail) ---
# JSON da Service Account em uma linha (ou base64) — ver lib/drive.ts:
GOOGLE_SERVICE_ACCOUNT_JSON=
DRIVE_FOLDER_ID=

# --- E-mail transacional + automações (skills: stripe-drive-checkout, email-automation) ---
EMAIL_API_KEY=re_xxx
EMAIL_FROM="EbookDrive <suporte@seudominio.com>"
SUPPORT_EMAIL=suporte@seudominio.com

# --- Banco de dados (registro de vendas + eventos do painel admin) ---
# Postgres (ex: Supabase / Vercel Postgres). Usado por lib/db.ts.
DATABASE_URL=

# --- Painel admin (rota protegida — prompt §9) ---
# Segredo para assinar a sessão de admin (gerar valor aleatório forte):
ADMIN_SESSION_SECRET=
# E-mails autorizados a acessar o admin (separados por vírgula) — usado no magic link:
ADMIN_ALLOWED_EMAILS=

# --- Conversion tracking (skill: conversion-tracking) ---
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
GA4_API_SECRET=
NEXT_PUBLIC_META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=
